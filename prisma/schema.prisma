generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Category {
  id           Int       @id @default(autoincrement())
  name         String    @db.VarChar(100)
  slug         String    @unique
  description  String?
  displayOrder Int       @default(999)
  products     Product[]
}

model Product {
  id           Int                 @id @default(autoincrement())
  name         String              @unique @db.VarChar(150)
  description  String?
  viewCount    Int                 @default(0)
  displayOrder Int                 @default(999)
  categoryId   Int
  movements    InventoryMovement[]
  category     Category            @relation(fields: [categoryId], references: [id])
  images       ProductImage[]
  variants     ProductVariant[]
  views        ProductView[]
}

model ProductView {
  id        Int      @id @default(autoincrement())
  ip        String   @db.VarChar(45)
  viewedAt  DateTime @default(now())
  productId Int
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([ip, productId])
}

model ProductImage {
  id        Int     @id @default(autoincrement())
  url       String  @db.VarChar(255)
  isPrimary Boolean @default(false)
  order     Int     @default(0)
  productId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductVariant {
  id          Int                 @id @default(autoincrement())
  sku         String              @unique
  barcode     String?             @db.VarChar(100)
  name        String?             @db.VarChar(200)
  price       Decimal             @default(0.0) @db.Decimal(12, 2)
  stock       Int                 @default(0)
  minStock    Int                 @default(5)
  unit        String              @default("pza")
  material    String?             @db.VarChar(50)
  measureType String?             @db.VarChar(50)
  productId   Int
  movements   InventoryMovement[]
  product     Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  dimensions  VariantDimension[]
}

model QuoteRequest {
  id         Int         @id @default(autoincrement())
  customerId Int?        
  customer   Customer?   @relation(fields: [customerId], references: [id])
  company    String
  contact    String
  phone      String
  email      String
  status     String      @default("pending")
  createdAt  DateTime    @default(now())
  items      QuoteItem[]
}

model QuoteItem {
  id             Int          @id @default(autoincrement())
  productName    String
  sku            String
  quantity       Int
  price          Decimal      @db.Decimal(12, 2)
  quoteRequestId Int
  quoteRequest   QuoteRequest @relation(fields: [quoteRequestId], references: [id], onDelete: Cascade)
}

model VariantDimension {
  id             Int            @id @default(autoincrement())
  dimensionName  String         @db.VarChar(50)
  dimensionValue String         @db.VarChar(50)
  measureUnit    String?        @db.VarChar(30)
  displayOrder   Int            @default(1)
  variantId      Int
  variant        ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
}

model Customer {
  id                   Int            @id @default(autoincrement())
  name                 String         @db.VarChar(150)
  company              String?        @db.VarChar(150)
  email                String?        @unique @db.VarChar(100)
  password             String?        @db.VarChar(255)
  phone                String?        @db.VarChar(50)
  address              String?
  notes                String?
  resetPasswordToken   String?        @db.VarChar(255)
  resetPasswordExpires DateTime?
  createdAt            DateTime       @default(now())
  quotes               QuoteRequest[]
}

model InventoryMovement {
  id             Int             @id @default(autoincrement())
  movementType   String          @db.VarChar(20)
  quantity       Int
  previousStock  Int
  resultingStock Int
  unitCost       Decimal?        @db.Decimal(12, 2)
  totalCost      Decimal?        @db.Decimal(12, 2)
  reason         String?
  reference      String?         @db.VarChar(100)
  supplier       String?         @db.VarChar(150)
  createdAt      DateTime        @default(now())
  productId      Int
  variantId      Int?
  product        Product         @relation(fields: [productId], references: [id])
  variant        ProductVariant? @relation(fields: [variantId], references: [id])
}

model AdminUser {
  id        Int      @id @default(autoincrement())
  username  String   @unique @db.VarChar(50)
  password  String   @db.VarChar(255)
  role      String   @default("admin")
  createdAt DateTime @default(now())
}
